generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ────────────────────────────────────────────
// Enums
// ────────────────────────────────────────────

enum WorkspaceTier {
  FREE
  PRO
  ENTERPRISE
}

enum ContractStatus {
  PENDING
  PROCESSING
  EXTRACTED
  APPROVED
  REJECTED
  FAILED
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

// ────────────────────────────────────────────
// Models
// ────────────────────────────────────────────

model Workspace {
  id               String        @id @default(cuid())
  name             String
  tier             WorkspaceTier @default(FREE)
  stripeCustomerId String?       @unique @map("stripe_customer_id")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  users            User[]
  contracts        Contract[]
  activities       Activity[]
  subscriptions    Subscription[]
  incidents        Incident[]
  ictAssets        IctAsset[]
  policyDocs       PolicyDocument[]
  vendors          Vendor[]
  resilienceTests  ResilienceTest[]

  @@map("workspaces")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  image        String?
  passwordHash String?  @map("password_hash")
  role         UserRole @default(MEMBER)
  workspaceId  String   @map("workspace_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contracts  Contract[]
  activities Activity[]
  incidents  Incident[]

  @@index([workspaceId])
  @@map("users")
}

model Contract {
  id            String         @id @default(cuid())
  fileName      String         @map("file_name")
  fileUrl       String         @map("file_url")
  mimeType      String         @map("mime_type")
  status        ContractStatus @default(PENDING)
  extractedData Json?          @map("extracted_data")
  uploadedById  String         @map("uploaded_by_id")
  workspaceId   String         @map("workspace_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  uploadedBy User      @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  activities Activity[]

  @@index([workspaceId])
  @@index([status])
  @@map("contracts")
}

model Activity {
  id          String   @id @default(cuid())
  action      String
  userId      String   @map("user_id")
  contractId  String?  @map("contract_id")
  workspaceId String   @map("workspace_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contract  Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([createdAt])
  @@map("activities")
}

model Subscription {
  id                   String             @id @default(cuid())
  workspaceId          String             @map("workspace_id")
  stripeSubscriptionId String             @unique @map("stripe_subscription_id")
  stripePriceId        String             @map("stripe_price_id")
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd     DateTime           @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("subscriptions")
}

model Incident {
  id             String    @id @default(cuid())
  workspaceId    String    @map("workspace_id")
  title          String
  status         String
  severity       String
  description    String?
  reportedById   String?   @map("reported_by_id")
  resolvedAt     DateTime? @map("resolved_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  reportedBy     User?     @relation(fields: [reportedById], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@map("incidents")
}

model IctAsset {
  id             String    @id @default(cuid())
  workspaceId    String    @map("workspace_id")
  name           String
  category       String
  criticality    String
  riskScore      Float?    @map("risk_score")
  lastAssessedAt DateTime? @map("last_assessed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("ict_assets")
}

model PolicyDocument {
  id             String    @id @default(cuid())
  workspaceId    String    @map("workspace_id")
  title          String
  type           String
  status         String
  version        String
  fileUrl        String?   @map("file_url")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("policy_documents")
}

model Vendor {
  id             String    @id @default(cuid())
  workspaceId    String    @map("workspace_id")
  name           String
  category       String
  criticality    String
  status         String
  nextReviewAt   DateTime? @map("next_review_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("vendors")
}

model ResilienceTest {
  id             String    @id @default(cuid())
  workspaceId    String    @map("workspace_id")
  name           String
  type           String
  status         String
  findings       Int       @default(0)
  scheduledAt    DateTime? @map("scheduled_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("resilience_tests")
}
